{
  "name": "telegram-movie-bot",
  "version": "1.0.0",
  "description": "Full-featured Telegram Movie Bot with PostgreSQL",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "migrate": "ts-node src/database/migrate.ts",
    "lint": "eslint src/**/*.ts"
  },
  "dependencies": {
    "telegraf": "^4.16.3",
    "sequelize": "^6.37.1",
    "pg": "^8.11.5",
    "pg-hstore": "^2.3.4",
    "dotenv": "^16.4.5",
    "winston": "^3.13.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@types/pg": "^8.11.5",
    "typescript": "^5.4.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "@typescript-eslint/eslint-plugin": "^7.8.0",
    "@typescript-eslint/parser": "^7.8.0",
    "eslint": "^8.57.0"
  }
}
